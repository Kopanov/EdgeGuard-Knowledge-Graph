# direnv configuration — https://direnv.net/
#
# When you `cd` into this directory, direnv automatically:
#   1. Creates .venv if it doesn't exist
#   2. Activates .venv  (deactivates when you leave the directory)
#   3. Loads .env       (NEO4J_PASSWORD, MISP_API_KEY, etc.)
#
# One-time setup:
#   brew install direnv          # macOS
#   apt install direnv           # Debian/Ubuntu
#   echo 'eval "$(direnv hook bash)"' >> ~/.bashrc   # or zsh / fish
#   direnv allow                 # run once inside this directory

# ── 1. Auto-create and activate .venv ────────────────────────────────────────
layout python python3

# ── 2. Load .env (secrets — not committed to git) ────────────────────────────
if [ -f .env ]; then
  dotenv .env
else
  echo "direnv: .env not found — copy .env.example to .env and fill in your keys"
fi

# ── 3. Convenience: make src/ importable without PYTHONPATH fiddling ─────────
export PYTHONPATH="$PWD/src:${PYTHONPATH:-}"
