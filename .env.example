# EdgeGuard-KG Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# ── Required ──────────────────────────────────────────────────────────────────

# Neo4j connection
# Default matches docker-compose.yml (x-common-env): Bolt to the neo4j service from other containers.
# Running scripts on the host against a published port: use bolt://localhost:7687 instead.
NEO4J_URI=bolt://neo4j:7687
# HTTP API base for Browser / transactional HTTP (DAG quality curl). Compose defaults to http://neo4j:7474.
# NEO4J_HTTP=http://localhost:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Neo4j container (docker-compose.yml neo4j service only): JVM heap + pagecache + cgroup cap.
# Defaults are modest (2g heap, 1g pagecache, 4g container limit). For large baselines on a beefy workstation,
# raise in step — container limit must stay above heap + pagecache. See docs/DOCKER_SETUP_GUIDE.md.
# NEO4J_HEAP_INITIAL=4g
# NEO4J_HEAP_MAX=12g
# NEO4J_PAGECACHE=8g
# NEO4J_TX_MEMORY_MAX=4g          # Per-transaction memory cap (prevents OOM; all queries use apoc.periodic.iterate batching)
# NEO4J_CONTAINER_MEMORY_LIMIT=22g

# MISP connection
# From Docker Compose (Airflow / API / GraphQL containers): use a hostname that resolves INSIDE the
# container — not host-only names like misp.local unless you also fix DNS. Example when MISP is another
# compose stack on a shared network: https://misp_misp_1:443 (project_service_instance; yours may differ).
MISP_URL=https://your-misp-instance.local
MISP_API_KEY=your-misp-api-key-here
# If MISP_URL uses Docker DNS but Apache SNI / vhost expects another name (common: cert for localhost):
# EDGEGUARD_MISP_HTTP_HOST=localhost
# Self-signed dev MISP (set for every service that calls MISP — see EDGEGUARD_SSL_VERIFY below):
# EDGEGUARD_SSL_VERIFY=false
# MISP→Neo4j sync discovers events via /events/index + filter (restSearch fallback); override substring if needed.
# EDGEGUARD_MISP_EVENT_SEARCH=EdgeGuard

# ── Collector API Keys ─────────────────────────────────────────────────────────
# Leave blank to skip that collector (pipeline degrades gracefully).

OTX_API_KEY=
NVD_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
THREATFOX_API_KEY=

# ── EdgeGuard API ──────────────────────────────────────────────────────────────

# Public API key (set to a strong random value in production).
# Leave empty only for local development.
EDGEGUARD_API_KEY=

# Admin query endpoint (disabled by default).
# Set both variables to enable arbitrary Cypher execution.
EDGEGUARD_ENABLE_ADMIN_QUERY=false
EDGEGUARD_ADMIN_TOKEN=

# ── Security ───────────────────────────────────────────────────────────────────

# SSL verification for outbound HTTPS (MISP, collectors). Default true — required for production.
# Self-signed / private CA dev MISP: EDGEGUARD_SSL_VERIFY=false
# Alias: if EDGEGUARD_SSL_VERIFY is unset or empty, SSL_VERIFY is read (true|false).
# Not used: SSL_CERT_VERIFY (set EDGEGUARD_SSL_VERIFY instead).
EDGEGUARD_SSL_VERIFY=true

# Defense-in-depth — MISP tag-impersonation check (chip 5e). Without these
# allowlists configured, a MISP user (compromised account, federated peer,
# or internal user) can stamp ``original_source: "nvd"`` on a forged
# attribute and EdgeGuard will treat it as authoritative NVD data —
# corrupting MIN(r.source_reported_first_at) on the SOURCED_FROM edge.
#
# Configure AT LEAST ONE allowlist in production. EdgeGuard verifies the
# parent event's creator org (``Orgc.uuid`` / ``Orgc.name``) against the
# allowlist BEFORE honoring the source-truthful claim. Rejections fire
# the ``edgeguard_source_truthful_creator_rejected_total`` Prometheus
# counter (operator alerts on a non-zero rate; see PROMETHEUS_SETUP.md).
#
# When NEITHER allowlist is set (the default), the check is BYPASSED and
# behavior matches pre-chip-5e — backward-compat for pre-release
# environments. Source: ``src/source_trust.py``.
#
# UUID allowlist (RECOMMENDED — strong defense). Each entry MUST be a
# canonical 8-4-4-4-12 UUID; misconfigured entries get logged at WARNING
# and dropped (a non-UUID string in the env var would otherwise become a
# spoofing vector if a federated peer's Orgc.uuid coincidentally matches).
# EDGEGUARD_TRUSTED_MISP_ORG_UUIDS=11111111-1111-1111-1111-111111111111,22222222-2222-2222-2222-222222222222
#
# Name allowlist (case-insensitive fallback; useful when UUIDs aren't
# exposed by your MISP deployment). Comparison applies Unicode NFKC
# normalization + ``casefold`` — defends against fullwidth Latin
# variants, German ß, Turkish dotless-i. **Does NOT defend against
# Cyrillic / Greek lookalike attacks** (a homoglyph 'е' U+0435 is
# byte-distinct from ASCII 'e' even after NFKC). For deployments
# under active threat, prefer the UUID allowlist.
# Limitation: org names with literal commas are unsupported (split-char
# collision); use the UUID allowlist for any name with punctuation.
# EDGEGUARD_TRUSTED_MISP_ORG_NAMES=EdgeGuard Collectors,Internal Threat Intel

# ── Monitoring ─────────────────────────────────────────────────────────────────

# Grafana admin password (required; no insecure default).
GRAFANA_ADMIN_PASSWORD=changeme

# Prometheus basic-auth password (optional).
PROMETHEUS_ADMIN_PASSWORD=

# ── OpenTelemetry ──────────────────────────────────────────────────────────────

# OTLP endpoint for distributed tracing (leave empty to disable).
OTEL_EXPORTER_OTLP_ENDPOINT=
# Set to "true" only for local development without TLS on the collector.
OTEL_EXPORTER_OTLP_INSECURE=false

# ── GraphQL API ───────────────────────────────────────────────────────────────

# Port for the EdgeGuard GraphQL endpoint (mirrors ISIM GraphQL on port 4001).
EDGEGUARD_GRAPHQL_PORT=4001
EDGEGUARD_GRAPHQL_HOST=127.0.0.1

# Disable the interactive GraphiQL browser explorer in production.
EDGEGUARD_GRAPHQL_PLAYGROUND=false

# ── Airflow ────────────────────────────────────────────────────────────────────
#
# The airflow service image is built from Dockerfile.airflow (edgeguard-airflow:3.2.0-python3.12), which installs
# requirements-airflow-docker.txt — including neo4j and pymisp for MISP→Neo4j DAG tasks. If you only
# `pip install` inside a running container, packages are lost on recreate. Rebuild after clone or dep changes:
#   docker compose build airflow && docker compose up -d airflow
#
# Airflow 3.x requires an explicit JWT secret for the API server when using
# FabAuthManager (the default web-UI auth provider). Without it the API
# server fails to start with 'jwt_secret not set'. Generate once with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# and keep the value stable across restarts so issued tokens remain valid.
# AIRFLOW_API_AUTH_JWT_SECRET=

# Airflow connection URI for Neo4j (used by DAG if Airflow Connections are not configured).
AIRFLOW_CONN_NEO4J_DEFAULT=

# Docker Compose: memory limit for the airflow container (full MISP→Neo4j sync spikes Python RSS).
# Default is 12g — large MISP events (100K+ attributes) need 8-12GB for PyMISP JSON parsing.
# Lower to 4g only for small test deployments; raise if tasks still get SIGKILL (-9).
# AIRFLOW_MEMORY_LIMIT=12g

# Docker Compose only: metadata database for the Airflow container (internal Postgres).
# Defaults match docker-compose.yml. Airflow metadata uses PostgreSQL (see Apache Airflow DB docs for other backends).
# Use URL-safe passwords (no @ : / # ?) or the connection string in compose will break.
# AIRFLOW_POSTGRES_USER=airflow
# AIRFLOW_POSTGRES_PASSWORD=airflow
# AIRFLOW_POSTGRES_DB=airflow

# DAG preflight (pass through to Airflow container env): MISP API+DB must be up; workers optional.
# EDGEGUARD_MISP_HEALTH_REQUIRE_WORKERS=true
# EDGEGUARD_SKIP_MISP_PREFLIGHT=true   # emergency only — skips misp_health_check task logic

# MISP→Neo4j sync: max parsed items per Python chunk before Neo4j merge (limits RAM; default 500).
# Lower if Airflow worker is OOM-killed on large backfills (tens of thousands of attributes).
# "0" or "all" (case-insensitive) = single pass — entire sorted list in one chunk (OOM risk; expert/debug).
# EDGEGUARD_NEO4J_SYNC_CHUNK_SIZE=500
# EDGEGUARD_NEO4J_SYNC_CHUNK_SIZE=all
# Relationship definitions per Neo4j UNWIND batch (default 500).
# EDGEGUARD_REL_BATCH_SIZE=500
# Opt-in: run gc.collect() after each Neo4j sync chunk (not recommended in small workers).
# EDGEGUARD_DEBUG_GC=1

# MISP write throttling — pause between batch POSTs to prevent MISP memory exhaustion
# on large events (e.g. 95K NVD attributes). Increase on memory-constrained MISP hosts.
# EDGEGUARD_MISP_BATCH_THROTTLE_SEC=5.0
# Pause between fetching consecutive MISP events during sync (default 2.0s).
# EDGEGUARD_MISP_EVENT_FETCH_THROTTLE_SEC=2.0
# Events exceeding this attribute count are deferred to end of sync (small events first).
# Set to 0 to disable. Default 50000.
# EDGEGUARD_MAX_EVENT_ATTRIBUTES=50000
# MISP attribute-push batch size. Lower this on memory-constrained MISP hosts that
# 500 on large batches. Default 1000.
# EDGEGUARD_MISP_PUSH_BATCH_SIZE=1000
# Seconds to wait between failed-event retry passes — gives MISP time to recover
# from memory pressure / transient 5xx before re-issuing the fetch. Default 15.0.
# EDGEGUARD_MISP_RETRY_COOLDOWN_SEC=15.0

# Cross-process baseline mutex — prevents a manual `edgeguard baseline` run from
# racing the scheduled incremental DAG. Both honor the same sentinel file.
# Default: checkpoints/baseline_in_progress.lock under EDGEGUARD_BASE_DIR.
# EDGEGUARD_BASELINE_LOCK_PATH=/absolute/path/to/baseline_in_progress.lock
# Max age (seconds) before a stale lock is auto-cleared. Default 86400 (24h).
# EDGEGUARD_BASELINE_LOCK_MAX_AGE_SEC=86400

# IMPORTANT — ResilMesh deployment port conflict:
# ResilMesh runs Temporal workflow orchestration on port 8080 (the same default
# as the Airflow API server). When deploying EdgeGuard alongside a ResilMesh
# instance on the same host, change the API server port to avoid a silent
# collision. Airflow 3.x config key is AIRFLOW__API__PORT; the legacy
# AIRFLOW__WEBSERVER__WEB_SERVER_PORT is kept as a harmless no-op for
# rollback to a 2.11 image.
# AIRFLOW__API__PORT=8082
# AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8082

# ── Docker Compose examples (Airflow container sees different hostnames than your laptop) ──
# Use strong secrets in production — do not copy example passwords.
# From **inside** the Airflow container, Neo4j is the Compose **service** name (see docker-compose.yml):
#   NEO4J_URI=bolt://neo4j:7687
# MISP must be a hostname the Airflow container can open (often the MISP service name or Docker network alias), not host-only localhost:
#   MISP_URL=https://your-misp-service:443
# Example default Docker Compose naming for a project folder `misp`: https://misp_misp_1:443
# If Apache needs Host: localhost for TLS while the URL uses Docker DNS, see docs/MISP_SOURCES.md:
#   EDGEGUARD_MISP_HTTP_HOST=localhost
# Dev MISP with self-signed cert (set on scheduler + workers):
#   EDGEGUARD_SSL_VERIFY=false
# Long tasks / false zombies (e.g. NVD, full_neo4j_sync): docker-compose.yml sets on **airflow** (override in .env):
#   AIRFLOW__SCHEDULER__SCHEDULER_ZOMBIE_TASK_THRESHOLD (default 3600)
#   AIRFLOW__SCHEDULER__LOCAL_TASK_JOB_HEARTBEAT_SEC (default 30)
#   AIRFLOW__SCHEDULER__ZOMBIE_DETECTION_INTERVAL (default 60)
# See docs/HEARTBEAT.md
# AIRFLOW__SCHEDULER__SCHEDULER_ZOMBIE_TASK_THRESHOLD=7200

# ── Runtime Paths ──────────────────────────────────────────────────────────────

# Override default checkpoint directory (default: <project_root>/checkpoints/).
# EDGEGUARD_CHECKPOINT_DIR=

# Override default state directory (default: <project_root>/state/).
# EDGEGUARD_STATE_DIR=

# CORS origins allowed to call the query API (comma-separated).
EDGEGUARD_CORS_ORIGINS=http://localhost,http://localhost:3000

# ── Sector / zone keyword scoring (optional) ───────────────────────────────────
# Defaults: 1.5 — single keyword in a CVE description (body weight 1.5) can tag a sector.
# Raise to reduce false positives (e.g. 2.0 requires stronger multi-hit evidence).
# EDGEGUARD_ZONE_DETECT_THRESHOLD=1.5
# EDGEGUARD_ZONE_ITEM_THRESHOLD=1.5

# ── Duplicate avoidance (collectors + MISP) ────────────────────────────────────
# Before push: prefetch existing (type,value) on the target MISP event and skip matches.
# EDGEGUARD_MISP_PREFETCH_EXISTING_ATTRS=true
# OTX incremental: pulses with modified > cursor (minus overlap); first run uses lookback days.
# EDGEGUARD_OTX_INCREMENTAL_LOOKBACK_DAYS=3
# EDGEGUARD_OTX_INCREMENTAL_OVERLAP_SEC=300
# EDGEGUARD_OTX_INCREMENTAL_MAX_PAGES=25
# MITRE: If-None-Match on the STIX bundle (304 → skip re-parse/re-push). Baseline always full fetch.
# EDGEGUARD_MITRE_CONDITIONAL_GET=true

# ── Feature Flags ──────────────────────────────────────────────────────────────

# Enable Prometheus metrics server (port 8001).
EDGEGUARD_ENABLE_METRICS=false

# Metrics server bind address.
# Default is 127.0.0.1 (loopback only) — safe for shared ResilMesh deployments.
# Set to 0.0.0.0 only when Prometheus scrapes from a different host.
# EDGEGUARD_METRICS_HOST=127.0.0.1
# EDGEGUARD_METRICS_PORT=8001

# Enable OpenTelemetry developer console exporter (local dev only).
EDGEGUARD_DEV_MODE=false

# ── Collection limits ─────────────────────────────────────────────────────────
#
# Two separate limits for the two collection modes:
#
#   INCREMENTAL (regular cron runs — 2-3 day window)
#     EDGEGUARD_INCREMENTAL_LIMIT — max items per source per cron run.
#       200  → collect at most 200 items from each source (default, keeps runs fast)
#       500  → larger window if sources produce more data in 2-3 days
#         0  → no item cap (only time-range window applies — use with caution)
#
#   BASELINE (manual/one-time full historical load — DAG: edgeguard_baseline)
#     Airflow UI: Admin → Variables — BASELINE_COLLECTION_LIMIT (0 = unlimited) and BASELINE_DAYS (default 730).
#     Docker: optional env overrides (applied inside get_baseline_config(), after Variables):
#
# Quick 7-day smoke test (then remove or comment and restart airflow):
#   EDGEGUARD_BASELINE_DAYS=7
#   EDGEGUARD_BASELINE_COLLECTION_LIMIT=1000
#
# See docs/BASELINE_SMOKE_TEST.md
#
# BASELINE_COLLECTION_LIMIT=0
#
#   EDGEGUARD_MAX_ENTRIES — hard global override for all runs.
#     When set to a non-zero value, overrides INCREMENTAL_LIMIT for every source.
#     Leave at 0 (default) to use the incremental/baseline limits above.
#
EDGEGUARD_INCREMENTAL_LIMIT=200
# EDGEGUARD_MAX_ENTRIES=0
#
# Optional: limit which collectors run (Airflow + run_pipeline Step 2).
# Comma-separated canonical names; unset = all enabled.
# Use "none" or "-" alone to disable all external collectors (tasks skip; DAG continues).
# Canonical names: otx, nvd, cisa, mitre, virustotal, virustotal_enrich, abuseipdb,
#   threatfox, urlhaus, cybercure, feodo, sslbl
# EDGEGUARD_COLLECT_SOURCES=otx,nvd,cisa
# EDGEGUARD_COLLECT_SOURCES=
